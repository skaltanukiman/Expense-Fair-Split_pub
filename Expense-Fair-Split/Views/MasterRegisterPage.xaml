<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:localization="clr-namespace:Expense_Fair_Split.Localization"
             x:Class="Expense_Fair_Split.Views.MasterRegisterPage"
             Title="マスタ編集">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,280,30,0"
            Spacing="25">
            <Label
             Text="{x:Static localization:XamlText.MasterRegisterText}"
             FontSize="17"
             FontAttributes="Bold"
             HorizontalOptions="Center"
             Margin="0,0,0,0"/>

            <Button
                Text="{x:Static localization:XamlText.Account}"
                Clicked="OnAccountEdit"
                HorizontalOptions="Fill"
                Padding="0,20"
                FontSize="16"/>
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>