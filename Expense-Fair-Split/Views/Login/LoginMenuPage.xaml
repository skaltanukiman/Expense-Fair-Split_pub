<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:localization="clr-namespace:Expense_Fair_Split.Localization"
             x:Class="Expense_Fair_Split.Views.Login.LoginMenuPage"
             Title="ログイン">
    <ScrollView>
        <VerticalStackLayout
            Padding="50,150,50,150"
            Spacing="0">

            <Label
                Text="{Binding ErrMsg}"
                FontSize="14"
                TextColor="Red"
                IsVisible="{Binding ShowErrMsg}"
                Margin="0,0,0,20"
                />

            <Label 
                Text="登録されたメールアドレスと&#xa;パスワードを入力してください。"
                FontSize="18"
                HorizontalOptions="Start"
                Margin="0,0,0,30" />

            <Label 
               Text="{x:Static localization:XamlText.MailAddress}"
               FontSize="20"
               Margin="0,0,0,0" />
            <Entry
               Text="{Binding EmailAddress}"
               FontSize="20"
               Keyboard="Email"
               Placeholder="hohoho@gmail.com"
               Margin="0,0,0,10"/>

            <Label 
               Text="{x:Static localization:XamlText.PassWord}"
               FontSize="20"
               Margin="0,0,0,0" />
            <Entry
               Text="{Binding Password}"
               FontSize="20"
               IsPassword="True"
               Placeholder="PassWord"
               Margin="0,0,0,15"/>

            <Button
               Text="{x:Static localization:XamlText.Login}" 
               HorizontalOptions="Center"
               Clicked="InputCheckAndUserLogin"
               Padding="60,15"
               Margin="0,20,0,20"
               FontSize="16" />

            <VerticalStackLayout>
                <Label 
                    Text="登録されていない方は、"
                    FontSize="13"
                    Margin="0,0,0,0" />
                <HorizontalStackLayout>
                    <Label 
                       Text="アカウントを作成してください。"
                       FontSize="13"
                       Margin="0,0,0,0" />

                    <Label 
                       Text="{x:Static localization:XamlText.Create}"
                       FontSize="13"
                       Margin="0,0,0,0"
                       TextDecorations="Underline"
                       TextColor="Blue">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNewRegistration" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>