<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Expense_Fair_Split.Views.BillingDataConfirmPage"
             Shell.BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout
            Padding="50,0,50,50"
            Spacing="0">
            <Label 
                Text="請求内容確認"
                FontSize="22"
                HorizontalOptions="Center"
                Margin="0,0,0,40" />

            <Label
                Text="{Binding ProcessMsg}"
                FontSize="14"
                TextColor="Red"
                IsVisible="{Binding ShowProcessMsg}"
                Margin="0,0,0,20"
                />

            <Label
                Text="{Binding ErrMsg}"
                FontSize="14"
                TextColor="Red"
                IsVisible="{Binding ShowErrMsg}"
                Margin="0,0,0,20"
                />

            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Label
                    Text="From"
                    FontSize="18"
                    Grid.Row="0"/>
                <Label
                    Text="To"
                    FontSize="18"
                    Grid.Row="1" />
                <Label
                    Text="勘定"
                    FontSize="18"
                    Grid.Row="2" />
                <Label
                    Text="請求書日付"
                    FontSize="18"
                    Grid.Row="3"/>
                <Label
                    Text="請求割合"
                    FontSize="18"
                    Grid.Row="4" />
                <Label
                    Text="請求総金額"
                    FontSize="18"
                    Grid.Row="5" />
                <Label
                    Text="請求金額"
                    FontSize="18"
                    Grid.Row="6" />
                <Label
                    Text="備考"
                    FontSize="18"
                    Grid.Row="7" />

                <Label
                    Text="{Binding FromName}"
                    FontSize="18"
                    Grid.Row="0"
                    Grid.Column="1"/>
                <Label
                    Text="{Binding ToUserInfo.Name}"
                    FontSize="18"
                    Grid.Row="1"
                    Grid.Column="1"/>
                <Label
                    Text="{Binding AccInfo.AccName}"
                    FontSize="18"
                    Grid.Row="2"
                    Grid.Column="1"
                    />
                <Label
                    Text="{Binding NowDate, StringFormat='{}{0:yyyy/MM/dd}'}"
                    FontSize="18"
                    Grid.Row="3"
                    Grid.Column="1"/>
                <Label
                    Text="{Binding RatioInfo.RatioName}"
                    FontSize="18"
                    Grid.Row="4"
                    Grid.Column="1"/>
                <Label
                    Text="{Binding TotalAmount, StringFormat='{}{0:N0}'}"
                    FontSize="18"
                    Grid.Row="5"
                    Grid.Column="1"/>
                <Label
                    Text="{Binding AmountBilled, StringFormat='{}{0:N0}'}"
                    FontSize="18"
                    Grid.Row="6"
                    Grid.Column="1"/>
                <Label
                    Text="{Binding Note}"
                    FontSize="18"
                    Grid.Row="7"
                    Grid.Column="1"/>
            </Grid>

            <Label 
                Text="上記の内容でチケットを発行しますか？"
                FontSize="17"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                Margin="0,0,0,60" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100*"/>
                    <ColumnDefinition Width="100*"/>
                </Grid.ColumnDefinitions>
                <Button
                    Text="戻る" 
                    Clicked="PopBillingDataEntry"
                    HorizontalOptions="Start"
                    Padding="40,15"
                    FontSize="16"
                    Grid.Row="0"
                    Grid.Column="0"/>
                <Button
                    Text="発行" 
                    Clicked="OnPublishing"
                    HorizontalOptions="End"
                    Padding="40,15"
                    FontSize="16"
                    Grid.Column="1"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>